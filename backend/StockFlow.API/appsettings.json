{
  "ConnectionStrings": {
    // Local SQL Server connection for development environment
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=StockFlowDb;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Jwt": {
    // JWT issuer (API identity)
    "Issuer": "StockFlow.API",

    // Intended audience (frontend/client)
    "Audience": "StockFlow.Angular",

    // Secret key used to sign tokens
    // NOTE: Should be moved to environment variables in production
    "SecretKey": "THIS_IS_A_DEVELOPMENT_SECRET_KEY_FOR_STOCKFLOW_AUTH_123456789",

    // Token expiration time in minutes
    "ExpiryMinutes": 60
  },

  "Logging": {
    "LogLevel": {
      // Default logging level for application
      "Default": "Information",

      // Reduce noise from framework logs
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Allowed hosts for incoming requests (use specific domains in production)
  "AllowedHosts": "*"
}